generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.VarChar(36)
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  email        String?  @unique @db.VarChar(100)
  role         Int      @default(0) @db.TinyInt
  storageQuota BigInt   @default(10737418240) @map("storage_quota")
  storageUsed  BigInt   @default(0) @map("storage_used")
  status       Int      @default(1) @db.TinyInt
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  files           File[]
  shares          Share[]
  downloadLogs    DownloadLog[]
  
  @@index([username])
  @@index([email])
  @@index([role])
  @@map("users")
}

model File {
  id            String      @id @default(uuid()) @db.VarChar(36)
  userId        String      @map("user_id") @db.VarChar(36)
  filename      String      @db.VarChar(255)
  originalName  String      @map("original_name") @db.VarChar(255)
  filePath      String      @map("file_path") @db.VarChar(500)
  fileSize      BigInt      @map("file_size")
  mimeType      String?     @map("mime_type") @db.VarChar(100)
  fileHash      String?     @map("file_hash") @db.VarChar(64)
  thumbnail     Bytes?      @db.LongBlob
  visibility    Int         @default(0) @db.TinyInt
  downloadCount Int         @default(0) @map("download_count")
  isDeleted     Int         @default(0) @map("is_deleted") @db.TinyInt
  deletedAt     DateTime?   @map("deleted_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares        Share[]
  downloadLogs  DownloadLog[]
  
  @@index([userId])
  @@index([fileHash])
  @@index([visibility])
  @@index([createdAt(sort: Desc)])
  @@index([isDeleted])
  @@map("files")
}

model Share {
  id              String    @id @default(uuid()) @db.VarChar(36)
  fileId          String    @map("file_id") @db.VarChar(36)
  userId          String    @map("user_id") @db.VarChar(36)
  shareCode       String    @unique @map("share_code") @db.VarChar(16)
  accessPassword  String?   @map("access_password") @db.VarChar(255)
  expireAt        DateTime? @map("expire_at")
  maxDownloads    Int       @default(-1) @map("max_downloads")
  downloadCount   Int       @default(0) @map("download_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  
  file            File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  downloadLogs    DownloadLog[]
  
  @@index([shareCode])
  @@index([expireAt])
  @@index([userId])
  @@map("shares")
}

model DownloadLog {
  id            String    @id @default(uuid()) @db.VarChar(36)
  fileId        String    @map("file_id") @db.VarChar(36)
  userId        String?   @map("user_id") @db.VarChar(36)
  shareId       String?   @map("share_id") @db.VarChar(36)
  ipAddress     String?   @map("ip_address") @db.VarChar(45)
  userAgent     String?   @map("user_agent") @db.VarChar(500)
  downloadSize  BigInt?   @map("download_size")
  createdAt     DateTime  @default(now()) @map("created_at")
  
  file          File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  share         Share?    @relation(fields: [shareId], references: [id], onDelete: SetNull)
  
  @@index([fileId])
  @@index([userId])
  @@index([createdAt])
  @@map("download_logs")
}
