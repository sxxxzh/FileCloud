{
  "name": "szhao-cloud-storage",
  "version": "1.0.0",
  "description": "个人云盘后端服务 - Copyright szhAo",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "cross-env NODE_ENV=test nodemon src/app.js",
    "prod": "cross-env NODE_ENV=production node src/app.js",
    "db:generate": "node scripts/prisma.js generate",
    "db:push": "node scripts/prisma.js db push",
    "db:push:test": "cross-env NODE_ENV=test node scripts/prisma.js db push",
    "db:push:prod": "cross-env NODE_ENV=production node scripts/prisma.js db push",
    "db:migrate": "node scripts/prisma.js migrate dev",
    "db:migrate:test": "cross-env NODE_ENV=test node scripts/prisma.js migrate dev",
    "db:migrate:prod": "cross-env NODE_ENV=production node scripts/prisma.js migrate deploy",
    "db:studio": "node scripts/prisma.js studio",
    "db:studio:test": "cross-env NODE_ENV=test node scripts/prisma.js studio",
    "init:admin": "node src/scripts/initAdmin.js",
    "init:admin:test": "cross-env NODE_ENV=test node src/scripts/initAdmin.js",
    "init:admin:prod": "cross-env NODE_ENV=production node src/scripts/initAdmin.js"
  },
  "keywords": [
    "cloud-storage",
    "file-upload",
    "file-sharing"
  ],
  "author": "szhAo",
  "license": "MIT",
  "dependencies": {
    "@koa/multer": "^4.0.0",
    "@prisma/client": "^5.7.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "koa": "^2.14.2",
    "koa-body": "^6.0.1",
    "koa-router": "^12.0.1",
    "koa-static": "^5.0.0",
    "multer": "^1.4.5-lts.1",
    "redis": "^4.6.12",
    "sharp": "^0.34.5",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
